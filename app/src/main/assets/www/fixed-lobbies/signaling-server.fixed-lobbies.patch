+function ensureAllowedLobby(code, leaderId) {
+  let lobby = lobbies.get(code);
+  if (!lobby) {
+    lobby = {
+      code,
+      peers: new Set(),
+      leader: leaderId,
+      term: 1,
+      maxPlayers: config.maxPlayers,
+    };
+    lobbies.set(code, lobby);
+    log("created in-memory lobby", code, "leader", leaderId);
+  }
+  return lobby;
+}
+
+function removePeerFromLobby(ws, notify = true) {
+  if (!ws.lobby) return;
+
+  const lobby = lobbies.get(ws.lobby);
+  if (!lobby) {
+    ws.lobby = null;
+    return;
+  }
+
+  const wasMember = lobby.peers.delete(ws.id);
+  if (wasMember && notify) {
+    for (const pid of lobby.peers) {
+      send(clients.get(pid), { type: "disconnect", id: ws.id });
+    }
+  }
+
+  if (lobby.leader === ws.id) {
+    const nextLeader = lobby.peers.values().next().value;
+    if (nextLeader) {
+      lobby.leader = nextLeader;
+      lobby.term += 1;
+      log("new leader", lobby.code, nextLeader, "term", lobby.term);
+    }
+  }
+
+  if (lobby.peers.size === 0) {
+    lobbies.delete(lobby.code);
+    log("removed empty in-memory lobby", lobby.code);
+  } else if (wasMember) {
+    broadcastLobby(lobby);
+  }
+
+  ws.lobby = null;
+}
+
+function joinAllowedLobby(ws, msg, mode) {
+  if (!ws.id) {
+    sendError(ws, "not-authenticated", "Send hello before create/join.", msg.rid);
+    return;
+  }
+
+  const code = requestedLobbyCode(msg);
+  if (!code || !config.allowedLobbies.has(code)) {
+    sendError(
+      ws,
+      "lobby-not-found",
+      "Missing or disallowed lobby id. Use index.html?id=XXX where XXX is in lobby-config.json.",
+      msg.rid
+    );
+    return;
+  }
+
+  const lobby = ensureAllowedLobby(code, ws.id);
+
+  if (!lobby.peers.has(ws.id) && lobby.peers.size >= lobby.maxPlayers) {
+    sendError(ws, "lobby-is-full", `Lobby ${code} already has ${lobby.maxPlayers} players.`, msg.rid);
+    return;
+  }
+
+  if (ws.lobby && ws.lobby !== code) {
+    removePeerFromLobby(ws, true);
+  }
+
+  const wasAlreadyMember = lobby.peers.has(ws.id);
+  lobby.peers.add(ws.id);
+  ws.lobby = code;
+
+  // If the old leader vanished without a clean close, keep a valid leader.
+  if (!lobby.leader || !lobby.peers.has(lobby.leader)) {
+    lobby.leader = ws.id;
+    lobby.term += 1;
+  }
+
+  const info = lobbyInfo(lobby);
+  send(ws, {
+    type: "joined",
+    rid: msg.rid,
+    lobbyInfo: info,
+  });
+
+  try {
+    fs.writeFileSync(CURRENT_LOBBY_FILE, code + "\n");
+  } catch (err) {
+    log("could not write current lobby file", CURRENT_LOBBY_FILE, err.message);
+  }
+
+  log(`${mode} OK`, code, "peer", ws.id, "players", info.players.join(","));
+
+  // New peer connects to existing peers only after successful join.
+  if (!wasAlreadyMember) {
+    for (const pid of lobby.peers) {
+      if (pid === ws.id) continue;
+      const other = clients.get(pid);
+      if (!other) continue;
+
+      // Preserve the original polarity: existing peer is impolite/leader side,
+      // newly joined peer is polite/joiner side. This reduces offer glare.
+      send(other, { type: "connect", id: ws.id, polite: false });
+      send(ws, { type: "connect", id: pid, polite: true });
+    }
+  }
+
+  broadcastLobby(lobby);
+}
+
+function sameLobby(sourceWs, recipientId) {
+  if (!sourceWs.lobby) return false;
+  const lobby = lobbies.get(sourceWs.lobby);
+  return !!lobby && lobby.peers.has(sourceWs.id) && lobby.peers.has(recipientId);
+}
+
+function isOfferDescription(msg) {
+  const desc =
+    msg.description ||
+    msg.desc ||
+    msg.sdp ||
+    msg.data ||
+    (msg.payload && (msg.payload.description || msg.payload.sdp));
+
+  return !!desc && desc.type === "offer";
+}
+
+function relayWebRTC(ws, msg) {
+  const recipientId = msg.recipient || msg.to || msg.id;
+  if (!recipientId || !clients.has(recipientId)) {
+    log("drop", msg.type, "from", ws.id, "missing recipient", recipientId);
+    return;
+  }
+
+  if (!sameLobby(ws, recipientId)) {
+    log("drop", msg.type, "from", ws.id, "to", recipientId, "not same lobby");
+    return;
+  }
+
+  const lobby = lobbies.get(ws.lobby);
+
+  // Optional anti-glare protection: only the lobby leader may originate SDP offers.
+  // Answers and ICE candidates are still relayed in both directions.
+  if (
+    config.dropOffersFromNonLeader &&
+    msg.type === "description" &&
+    isOfferDescription(msg) &&
+    ws.id !== lobby.leader
+  ) {
+    log("drop non-leader offer", "lobby", lobby.code, "from", ws.id, "leader", lobby.leader);
+    return;
+  }
+
+  send(clients.get(recipientId), msg);
+}
+
+function relayLobbyEvent(ws, msg) {
+  if (!ws.lobby || !lobbies.has(ws.lobby)) return;
+  const lobby = lobbies.get(ws.lobby);
+  for (const pid of lobby.peers) {
+    if (pid !== ws.id) send(clients.get(pid), msg);
+  }
+}
+
+const server = http.createServer((req, res) => {
+  if (req.url === "/health") {
+    res.writeHead(200, { "content-type": "application/json" });
+    res.end(JSON.stringify({
+      ok: true,
+      allowedLobbies: config.allowedLobbies.size,
+      activeLobbies: lobbies.size,
+      clients: clients.size,
+    }) + "\n");
+    return;
+  }
+
+  if (DEBUG && req.url === "/debug/lobbies") {
+    res.writeHead(200, { "content-type": "application/json" });
+    res.end(JSON.stringify(
+      [...lobbies.values()].map(lobbyInfo),
+      null,
+      2
+    ) + "\n");
+    return;
+  }
+
+  res.writeHead(404, { "content-type": "text/plain" });
+  res.end("not found\n");
+});
